# ── Database ──────────────────────────────────────────────────────────────────
# Spin up MongoDB with: docker compose up -d  (from project root)
MONGO_URI=mongodb://localhost:27017
DB_NAME=papairus

# ── STT ───────────────────────────────────────────────────────────────────────
# "api"   → OpenAI Whisper API (recommended on CPU, ~$0.006/min)
# "local" → offline; requires ffmpeg + whisper install, slow on CPU
WHISPER_BACKEND=api
WHISPER_MODEL_SIZE=base

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Controls which LLM is used for tag extraction AND chat: gemini | openai | ollama
LLM_PROVIDER=gemini

# ── Chat / Persona ────────────────────────────────────────────────────────────
# Default persona for POST /chat — overridable per request
# Options: stoic | socratic | analyst
CHAT_PERSONA=stoic

# ── API Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

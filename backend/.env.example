# ── LLM Analysis — Layer 2 (theme + causal + emotion enrichment) ──────────────

# Provider: "gemini" (default), "openai", or "ollama" (fully local, no key needed)
LLM_PROVIDER=gemini

# Gemini — get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (alternative) — uncomment to use instead
# OPENAI_MODEL=gpt-4o-mini

# Ollama (fully local) — uncomment + run: ollama pull mistral
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=mistral

# ── MongoDB Configuration
MONGO_URI=mongodb://localhost:27017
DB_NAME=papairus

# ── Whisper STT Configuration ─────────────────────────────────────────────────

# Backend: "api" (OpenAI Cloud API) or "local" (local model - NO API KEY NEEDED)
# Default: "api" if OPENAI_API_KEY is set, otherwise "local"
WHISPER_BACKEND=api

# ── For Cloud API Backend (WHISPER_BACKEND=api) ──
# OpenAI API Key (Required only for cloud API)
# Get your key from: https://platform.openai.com/api-keys
# Cost: $0.006 per minute of audio
OPENAI_API_KEY=your_openai_api_key_here

# ── For Local Backend (WHISPER_BACKEND=local) ──
# NO API KEY NEEDED! Runs completely offline and FREE
# Local Whisper Model Size
# Options: tiny, base, small, medium, large
# - tiny: ~1GB, fastest, least accurate
# - base: ~1GB, good balance [DEFAULT]
# - small: ~2GB, better accuracy
# - medium: ~5GB, high accuracy (needs good GPU)
# - large: ~10GB, best accuracy (needs powerful GPU)
WHISPER_MODEL_SIZE=base
